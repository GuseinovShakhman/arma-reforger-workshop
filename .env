# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, zero-config for local dev)
DATABASE_URL=sqlite:///./workshop.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://user:password@db:5432/workshop

# ── Scraper ──────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_SECONDS=60
SCRAPE_DETAIL_DELAY_MS=500

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
